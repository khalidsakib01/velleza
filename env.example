# SSLCommerz mode: sandbox for testing, live for real transactions
SSL_MODE=sandbox

# SSLCommerz credentials
# For local sandbox testing you can still use:
# SSL_STORE_ID=testbox
# SSL_STORE_PASS=qwerty
SSL_STORE_ID=your_store_id_here
SSL_STORE_PASS=your_store_password_here

# Optional explicit endpoint overrides
# SSL_INIT_URL=
# SSL_VALIDATE_URL=

# App URLs
FRONTEND_URL=https://velleza.vercel.app
BACKEND_URL=https://velleza.vercel.app

# Optional explicit callback overrides
# SUCCESS_URL=https://velleza.vercel.app/payment/success
# FAIL_URL=https://velleza.vercel.app/payment/fail
# CANCEL_URL=https://velleza.vercel.app/payment/cancel
# IPN_URL=https://velleza.vercel.app/payment/ipn

# Local server port
PORT=4000

